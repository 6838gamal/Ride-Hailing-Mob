modules = ["web", "swift-5.8", "bash", "python-3.11"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flutter build web --profile && python3 -m http.server 5000 --bind 0.0.0.0 --directory build/web"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
